{
  "name": "voku/agent-map",
  "type": "library",
  "description": "Compact PHP repository symbol maps for coding-agent navigation.",
  "license": "MIT",
  "bin": [
    "bin/agent-map"
  ],
  "autoload": {
    "psr-4": {
      "voku\\AgentMap\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "voku\\AgentMap\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.2",
    "helgesverre/toon": "^3.1",
    "voku/simple-php-code-parser": "^0.22"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0"
  },
  "scripts": {
    "post-install-cmd": "@php scripts/install-bin-proxy.php",
    "post-update-cmd": "@php scripts/install-bin-proxy.php",
    "test": "phpunit",
    "phpstan": "phpstan analyse --configuration=phpstan.neon.dist",
    "ci": [
      "@composer validate --strict",
      "@test",
      "@phpstan"
    ]
  }
}
